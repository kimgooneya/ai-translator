# AI 번역기 — 관리형 키 (admin-managed) 안내

# 이 앱은 관리자가 중앙에서 관리하는 API 키를 사용합니다 (BYOK 폐지).
# 사용자는 키를 입력하지 않으며, 어드민이 /admin/providers 에서 키를 등록합니다.
# 키는 AES-256-GCM으로 암호화되어 Supabase provider_keys 테이블에 저장되며,
# 복호화는 오직 /api/translate 서버 핸들러 내 메모리에서만 이루어집니다.

# -----------------------------------------------------------------------------
# Supabase (필수) — https://supabase.com
# 프로젝트 생성 → Project Settings → API → 아래 값 복사.
# PUBLIC_* 값은 브라우저에 노출되어도 안전합니다 — 모든 테이블은 RLS로 보호됩니다.
# -----------------------------------------------------------------------------
PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# -----------------------------------------------------------------------------
# 서버 전용 시크릿 — 절대 브라우저에 노출 금지 (src/lib/server/** 에서만 import).
# -----------------------------------------------------------------------------

# Supabase service_role 키 — RLS를 우회하는 전 권한 키.
# Project Settings → API → "service_role secret"에서 복사.
# 어드민 키 관리(provider_keys 조회/복호화)와 usage_logs 적재에만 사용됩니다.
# $env/static/private 로만 import → Vite가 클라이언트 번들에 포함하지 않습니다.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# provider_keys 암호화용 AES-256-GCM 마스터 키 (32바이트 = base64 44자).
# 생성 예: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# 이 값이 바뀌면 기존에 암호화된 모든 provider_keys를 다시 등록해야 합니다.
ENCRYPTION_KEY=base64_32_byte_key
